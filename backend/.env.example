# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=plivio_db
DB_USER=plivio_user
DB_PASSWORD=change_me_strong_password

# ─── Cache (Redis) ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret_minimum_64_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_minimum_64_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Security ─────────────────────────────────────────────────────────────────
# Comma-separated list of IPs allowed to access /api/admin routes
ADMIN_WHITELIST_IPS=127.0.0.1,::1,::ffff:127.0.0.1

# Rate limiter: max requests per window
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
