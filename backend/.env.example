# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────────────
# Option A – Neon / hosted Postgres (recommended)
# Paste your full connection string from neon.tech → Connect → Connection string
DATABASE_URL=postgresql://neondb_owner:password@ep-xxxx-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Option B – Local Postgres (leave DATABASE_URL empty to use these instead)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=plivio_db
# DB_USER=plivio_user
# DB_PASSWORD=change_me

# ─── Cache (Redis) ────────────────────────────────────────────────────────────
# Optional – leave empty to use in-memory rate-limit fallback
# Free cloud Redis: https://upstash.com  (copy the rediss:// URL)
# REDIS_URL=rediss://:password@host:6380

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate secrets:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret_minimum_64_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_minimum_64_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Security ─────────────────────────────────────────────────────────────────
# Comma-separated IPs allowed to reach /api/admin routes
ADMIN_WHITELIST_IPS=127.0.0.1,::1,::ffff:127.0.0.1

# ─── Rate limiter ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# For Gmail: enable 2FA, then create an App Password at myaccount.google.com/apppasswords
# For production use Resend (resend.com) or SendGrid (100 free emails/day)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM="Plivio <noreply@plivio.com>"

# ─── App URL (used in email links) ────────────────────────────────────────────
# Must match your frontend URL exactly – no trailing slash
APP_URL=http://localhost:5173

# ─── PayMongo (Philippine payment gateway) ────────────────────────────────────
# Sign up at dashboard.paymongo.com
# Use test keys during development (prefix: sk_test_ / pk_test_)
# Use live keys in production (prefix: sk_live_ / pk_live_)
PAYMONGO_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
PAYMONGO_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
# Webhook secret from PayMongo dashboard → Developers → Webhooks
# Set webhook URL to: https://yourdomain.com/api/subscriptions/webhook
PAYMONGO_WEBHOOK_SECRET=whsk_xxxxxxxxxxxxxxxxxxxx
